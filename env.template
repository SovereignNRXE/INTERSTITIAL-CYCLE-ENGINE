# ─────────────────────────────────────────────
# INTERSTITIAL CYCLE ENGINE — CREDENTIALS
# Copy this file to .env and fill in values.
# Only ANTHROPIC_API_KEY is required to run.
# Social platforms are optional — skip any
# platform by leaving its fields empty.
# ─────────────────────────────────────────────

# Anthropic (REQUIRED)
ANTHROPIC_API_KEY=

# Mastodon (optional)
MASTODON_ACCESS_TOKEN=
MASTODON_INSTANCE=mastodon.social

# Bluesky (optional)
BSKY_HANDLE=yourhandle.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@yourchannel

# LinkedIn (optional — token expires every 60 days)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXXXXXXXXXX

# Paths (defaults work if you run from the project folder)
OUTPUT_DIR=./output
DATA_FILE=./output/INTERSTITIAL_DATA.xlsx
ENGINEERING_FILE=./output/ICE_ENGINEERING.xlsx
SPIRAL_PATH=./spiral_symbol.png
CYCLE_FILE=./output/cycle_counter.txt
RESET_INTERVAL=30
