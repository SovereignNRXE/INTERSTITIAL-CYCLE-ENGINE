# ─────────────────────────────────────────────
# INTERSTITIAL CYCLE ENGINE — .gitignore
# ─────────────────────────────────────────────

# Credentials — never commit
.env

# Engine output — can grow very large
output/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Logs (outside output/)
*.log

# Test artefacts
_build_test/
